.SH EXAMPLES
.SS Job submission
.RS
.nf
from appform_sdk import AppformClient

client = AppformClient(
    base_url="https://your-server.com",
    access_key="YOUR_KEY",
    access_key_secret="YOUR_SECRET",
    username="your_username",
)

result = client.jobs.submit(
    app_id="fluent",
    params={
        "JH_JOB_NAME": "simulation_001",
        "JH_CAS": "/home/user/cases/test.cas",
        "JH_NCPU": "16",
        "JH_ITERATION": "1000",
        "JH_GUI_ENABLED": "off",
    },
)
print(f"Job ID: {result['data']}")

# List and monitor
jobs = client.jobs.list_jobs(status_filter=["RUN"])
print(f"Running jobs: {jobs['data']['total']}")

# Stop a job
client.jobs.stop("494825")
.fi
.RE
.SS Session management
.RS
.nf
client = AppformClient(base_url="https://your-server.com")
client.auth.login("user", "pass")

# Start a session
result = client.sessions.start(
    app_id="gedit",
    start_new=True,
    cwd="${HOME}",
)

# List current user sessions
sessions = client.sessions.list()

# Connect and auto-launch client
client.sessions.connect_and_launch(sessions["data"][0]["sessionId"])
.fi
.RE
.SS File operations
.RS
.nf
client = AppformClient(base_url="https://your-server.com")
client.auth.login("user", "pass")

# List directory
files = client.files.list(path="/home/user")

# Upload with progress
client.files.upload(
    file_path="./local_file.txt",
    remote_path="/home/user/",
    on_progress=lambda name, current, total:
        print(f"{name}: {current}/{total}"),
)

# Download
client.files.download(
    remote_path="/home/user/output.txt",
    local_path="./output.txt",
)
.fi
.RE
.SS Using Config
.RS
.nf
from appform_sdk import AppformClient, Config

# Load from config file (with environment)
config = Config(config_file="~/.appform/config.json", env="prod")
client = AppformClient(config=config)

# Or use environment variables
config = Config.from_env()
client = AppformClient(config=config)
.fi
.RE
